# Database
# LOCAL
DATABASE_URL=postgresql://postgres:password@localhost:5432/nama
# DOCKER
DATABASE_URL=postgresql://postgres:password@host.docker.internal:5432/nama

# JWT
SECRET_KEY=your-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173